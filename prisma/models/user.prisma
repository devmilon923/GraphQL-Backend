model User {
  id        Int           @id @unique @default(autoincrement())
  name      String
  email     String
  profile   String?
  oauthid   String
  provider  providerEnum? @default(google)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sessionId Session[]
  role      roleEnum      @default(user)

  @@unique([oauthid, email], name: "uniqueUser")
}

enum providerEnum {
  google
  facebook
}

enum roleEnum {
  user
  admin
}
