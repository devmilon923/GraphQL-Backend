model User {
  id        Int           @id @default(autoincrement())
  name      String
  email     String        @unique
  profile   String?
  oauthid   String
  provider  providerEnum? @default(google)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sessionId Session[]

  @@unique([id, oauthid, email])
}

enum providerEnum {
  google
  facebook
}
